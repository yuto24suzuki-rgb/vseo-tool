# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Ads API (Keyword Planner)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth2_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth2_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# YouTube Analytics API + Google Sheets API
# OAuth2 スコープ: youtube.readonly, spreadsheets
YOUTUBE_CLIENT_ID=your_oauth2_client_id_here
YOUTUBE_CLIENT_SECRET=your_oauth2_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here
# "mine" でログイン中のチャンネル、または UCxxxxxxxxxxxxxxxx 形式で指定
YOUTUBE_CHANNEL_ID=mine
# Google スプレッドシートの URL 末尾にある ID
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Backend server
PORT=3001
FRONTEND_URL=http://localhost:3000
