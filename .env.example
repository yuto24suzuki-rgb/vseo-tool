# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Ads API (Keyword Planner)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_oauth2_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth2_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# Google Sheets API (サービスアカウントキーをBase64エンコードした文字列)
# base64 encode: base64 -w0 credentials.json
GOOGLE_SERVICE_ACCOUNT_JSON=your_base64_encoded_service_account_json

# Lステップ チャンネルID (任意: 直接URLで流入経路ページへ移動する場合)
LSTEP_CHANNEL_ID=

# Backend server
PORT=3001
FRONTEND_URL=http://localhost:3000
